<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/survey_background"
    android:orientation="vertical"
    android:paddingLeft="18dp"
    android:paddingTop="44dp"
    android:paddingRight="18dp"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:fontFamily="sans-serif-medium"
        android:paddingBottom="18dp"
        android:text="Encuesta de Satisfacción"
        android:textColor="@color/survey_title"
        android:textSize="24sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="12dp"
        android:layout_weight="1"
        android:background="@drawable/bg_panel"
        android:clipToPadding="false"
        android:fadeScrollbars="true"
        android:padding="2dp"
        android:scrollbarSize="4dp"
        android:scrollbarThumbVertical="@drawable/bg_scrollbar_thumb"
        android:scrollbarTrackVertical="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/txtIntroduccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_intro"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="2dp"
                android:text="Queremos conocer su experiencia con nuestro servicio. Complete sus datos y responda la encuesta de satisfacción."
                android:textColor="@color/survey_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtDatosCliente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_question_badge"
                android:fontFamily="sans-serif-medium"
                android:text="Datos del cliente"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edtNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_box"
                android:fontFamily="sans-serif"
                android:hint="Nombre"
                android:inputType="textPersonName"
                android:minHeight="46dp"
                android:singleLine="true"
                android:textColor="@color/survey_text"
                android:textColorHint="@color/survey_text_secondary"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edtApellido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_box"
                android:fontFamily="sans-serif"
                android:hint="Apellido"
                android:inputType="textPersonName"
                android:minHeight="46dp"
                android:singleLine="true"
                android:textColor="@color/survey_text"
                android:textColorHint="@color/survey_text_secondary"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edtCorreo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_box"
                android:fontFamily="sans-serif"
                android:hint="Correo"
                android:inputType="textEmailAddress"
                android:minHeight="46dp"
                android:singleLine="true"
                android:textColor="@color/survey_text"
                android:textColorHint="@color/survey_text_secondary"
                android:textSize="15sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"
                android:background="@color/survey_border" />

            <LinearLayout
                android:id="@+id/layoutPreguntas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnGuardarEncuesta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_button_primary"
        android:fontFamily="sans-serif-medium"
        android:minHeight="48dp"
        android:text="Guardar Encuesta"
        android:textColor="@color/white" />

    <Button
        android:id="@+id/btnVerHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_secondary"
        android:fontFamily="sans-serif-medium"
        android:minHeight="48dp"
        android:text="Ver Historial"
        android:textColor="@color/survey_primary" />

</LinearLayout>
